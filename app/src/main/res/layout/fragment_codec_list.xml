<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.main.CodecListFragment">

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/recycler_view_divider"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.5"
        />
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/decoders_string"
        android:id="@+id/decoders_recycler_view_title"
        style="@style/TextAppearance.Material3.TitleMedium"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginStart="4dp"/>
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/encoders_string"
        android:id="@+id/encoders_recycler_view_title"
        android:layout_marginStart="4dp"
        style="@style/TextAppearance.Material3.TitleMedium"
        app:layout_constraintStart_toEndOf="@id/recycler_view_divider"
        app:layout_constraintTop_toTopOf="parent"
        />
    <androidx.recyclerview.widget.RecyclerView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:id="@+id/decoders_recycler_view"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
        app:layout_constraintStart_toStartOf="@id/decoders_recycler_view_title"
        app:layout_constraintTop_toBottomOf="@id/decoders_recycler_view_title"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@id/recycler_view_divider"
        android:layout_marginEnd="4dp"
        tools:listitem="@layout/codec_name_card_layout"
        tools:itemCount="3"
        />
    <androidx.recyclerview.widget.RecyclerView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:id="@+id/encoders_recycler_view"
        android:layout_marginEnd="4dp"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
        app:layout_constraintTop_toBottomOf="@id/encoders_recycler_view_title"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="@id/encoders_recycler_view_title"
        app:layout_constraintEnd_toEndOf="parent"
        tools:listitem="@layout/codec_name_card_layout"
        tools:itemCount="3"
        />

</androidx.constraintlayout.widget.ConstraintLayout>